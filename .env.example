# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Bootstrap Payment
NEXT_PUBLIC_ORANGE_MONEY_NUMBER=07XXXXXXXX
NEXT_PUBLIC_WAVE_NUMBER=05XXXXXXXX
SMS_WEBHOOK_SECRET=your-secret-here

# SMS replay protection
SMS_ALLOWED_IPS=72.62.237.25,127.0.0.1

# PayPal (diaspora credit card payments — personal account bootstrap)
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_MODE=sandbox

# Claude API (Ama chatbot)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Resend (email notifications)
RESEND_API_KEY=re_xxxxxxxxxxxx
NOTIFICATION_FROM_EMAIL=notifications@ecoleversity.com

# Web Push (generate VAPID keys with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-public-key
VAPID_PRIVATE_KEY=your-private-key

# WhatsApp — provider selection
# Values: "ailead" (default, primary) or "360dialog" (rollback)
WHATSAPP_PROVIDER=ailead

# Supabase Send SMS Hook — secret configured in Supabase dashboard
# (Auth → Hooks → Send SMS Hook → generate secret)
# Format: v1,whsec_<base64-secret>
SEND_SMS_HOOK_SECRET=v1,whsec_your-hook-secret

# WhatsApp — AILead (primary SaaS provider, multi-tenant)
AILEAD_API_URL=https://your-project.supabase.co/functions/v1/send-message
AILEAD_BUSINESS_ID=your-business-uuid
AILEAD_API_KEY=ak_live_xxxxxxxxxxxx
AILEAD_OTP_TEMPLATE_NAME=ecoleversity_otp_fr

# Phone number of the shared AILead WhatsApp business number that
# users message first (to open Meta's 24h service window). E.164
# format WITHOUT the leading + (wa.me format). Example: 22507123456
NEXT_PUBLIC_AILEAD_WHATSAPP_NUMBER=

# WhatsApp — 360dialog (rollback provider, direct BSP)
WHATSAPP_API_KEY=your-360dialog-api-key
