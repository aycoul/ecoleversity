# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Bootstrap Payment
NEXT_PUBLIC_ORANGE_MONEY_NUMBER=07XXXXXXXX
NEXT_PUBLIC_WAVE_NUMBER=05XXXXXXXX
SMS_WEBHOOK_SECRET=your-secret-here

# SMS replay protection
SMS_ALLOWED_IPS=72.62.237.25,127.0.0.1

# Flutterwave (diaspora credit card payments)
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY=FLWPUBK-xxxxx
FLUTTERWAVE_SECRET_KEY=FLWSECK-xxxxx
FLUTTERWAVE_SECRET_HASH=your-webhook-hash

# Claude API (Ama chatbot)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Resend (email notifications)
RESEND_API_KEY=re_xxxxxxxxxxxx
NOTIFICATION_FROM_EMAIL=notifications@ecoleversity.com

# Web Push (generate VAPID keys with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-public-key
VAPID_PRIVATE_KEY=your-private-key

# WhatsApp (360dialog)
WHATSAPP_API_KEY=your-360dialog-api-key
